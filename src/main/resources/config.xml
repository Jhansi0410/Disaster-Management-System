<?xml version="1.0" encoding="UTF-8"?>
<hibernate-configuration>
    <session-factory>

        <!-- Database connection settings -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/disaster_management</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">Jhansi@2004</property>

        <!-- JDBC connection pool (built-in) -->
        <property name="hibernate.connection.pool_size">10</property>

        <!-- SQL dialect for MySQL -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- Show SQL in console -->
        <property name="hibernate.show_sql">true</property>
       

        <!-- Automatically create/update tables -->
        <!-- Options: validate | update | create | create-drop -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Entity class mapping -->
        <mapping class="com.disaster.entity.User"/>
        <mapping class="com.disaster.entity.Admin"/>
        <mapping class="com.disaster.entity.Disaster"/>
        <mapping class="com.disaster.entity.Location"/>
        <mapping class="com.disaster.entity.Operation"/>
        <mapping class="com.disaster.entity.Request"/>
        <mapping class="com.disaster.entity.RescueTeam"/>
        <mapping class="com.disaster.entity.Resource"/>
        <mapping class="com.disaster.entity.Victim"/>
        

    </session-factory>
</hibernate-configuration>